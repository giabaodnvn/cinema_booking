<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Xác nhận đặt vé</title>
</head>
<body style="margin:0;padding:0;background-color:#0f0f0f;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#0f0f0f;padding:32px 16px;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;">

          <%# ── HEADER ── %>
          <tr>
            <td align="center" style="padding-bottom:28px;">
              <p style="margin:0;font-size:22px;font-weight:700;color:#ffffff;letter-spacing:-0.5px;">
                🎬 CinemaBooking
              </p>
            </td>
          </tr>

          <%# ── SUCCESS BANNER ── %>
          <tr>
            <td style="background-color:#14532d;border:1px solid #166534;border-radius:12px 12px 0 0;padding:24px;text-align:center;">
              <p style="margin:0 0 6px;font-size:28px;">✅</p>
              <p style="margin:0 0 4px;font-size:20px;font-weight:700;color:#ffffff;">Đặt vé thành công!</p>
              <p style="margin:0;font-size:14px;color:#86efac;">
                Mã đặt vé:
                <span style="font-family:monospace;font-weight:700;font-size:16px;color:#ffffff;background:#166534;padding:2px 8px;border-radius:4px;">
                  <%= @booking.booking_code %>
                </span>
              </p>
            </td>
          </tr>

          <%# ── TICKET CARD ── %>
          <tr>
            <td style="background-color:#111827;border:1px solid #1f2937;border-top:none;border-radius:0 0 12px 12px;padding:0;">

              <%# Movie info %>
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="padding:20px 24px;border-bottom:1px dashed #374151;">
                    <p style="margin:0 0 4px;font-size:18px;font-weight:700;color:#ffffff;"><%= @movie.title %></p>
                    <p style="margin:0;font-size:13px;color:#9ca3af;">
                      <%= @movie.age_rating.presence || "Mọi lứa tuổi" %> &nbsp;·&nbsp;
                      <%
                        h = @movie.duration / 60
                        m = @movie.duration % 60
                        duration_str = h > 0 ? (m > 0 ? "#{h}h #{m}m" : "#{h}h") : "#{m}m"
                      %>
                      <%= duration_str %>
                    </p>
                  </td>
                </tr>

                <%# Showtime details %>
                <tr>
                  <td style="padding:20px 24px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td width="50%" style="padding-bottom:16px;">
                          <p style="margin:0 0 2px;font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:0.5px;">Rạp chiếu</p>
                          <p style="margin:0;font-size:14px;color:#ffffff;font-weight:500;"><%= @cinema.name %></p>
                        </td>
                        <td width="50%" style="padding-bottom:16px;">
                          <p style="margin:0 0 2px;font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:0.5px;">Phòng chiếu</p>
                          <p style="margin:0;font-size:14px;color:#ffffff;font-weight:500;"><%= @room.name %></p>
                        </td>
                      </tr>
                      <tr>
                        <td width="50%">
                          <p style="margin:0 0 2px;font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:0.5px;">Ngày chiếu</p>
                          <p style="margin:0;font-size:14px;color:#ffffff;font-weight:500;">
                            <%= I18n.l(@showtime.start_time.to_date, format: :long) %>
                          </p>
                        </td>
                        <td width="50%">
                          <p style="margin:0 0 2px;font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:0.5px;">Giờ chiếu</p>
                          <p style="margin:0;font-size:14px;color:#ffffff;font-weight:500;">
                            <%= I18n.l(@showtime.start_time, format: :time) %> – <%= I18n.l(@showtime.end_time, format: :time) %>
                          </p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <%# Seats %>
                <tr>
                  <td style="padding:0 24px 20px;border-top:1px dashed #374151;">
                    <p style="margin:16px 0 10px;font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:0.5px;">Ghế ngồi</p>
                    <table cellpadding="0" cellspacing="4">
                      <tr>
                        <% @seats.each do |bs| %>
                          <td style="background:#1f2937;border:1px solid #374151;border-radius:6px;padding:6px 12px;text-align:center;">
                            <p style="margin:0;font-size:14px;font-weight:700;color:#ffffff;font-family:monospace;"><%= bs.seat.label %></p>
                            <p style="margin:0;font-size:11px;color:#9ca3af;text-transform:capitalize;"><%= bs.seat.seat_type %></p>
                          </td>
                        <% end %>
                      </tr>
                    </table>
                  </td>
                </tr>

                <%# Payment summary %>
                <tr>
                  <td style="padding:16px 24px;border-top:1px dashed #374151;border-bottom:1px solid #1f2937;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td>
                          <p style="margin:0 0 2px;font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:0.5px;">Trạng thái thanh toán</p>
                          <% if @payment&.pending? %>
                            <p style="margin:0;font-size:14px;color:#fbbf24;font-weight:500;">⏳ Chờ thanh toán</p>
                          <% elsif @payment&.completed? %>
                            <p style="margin:0;font-size:14px;color:#34d399;font-weight:500;">✅ Đã thanh toán</p>
                          <% end %>
                        </td>
                        <td align="right">
                          <p style="margin:0 0 2px;font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:0.5px;">Tổng tiền</p>
                          <p style="margin:0;font-size:22px;font-weight:700;color:#ffffff;">
                            <%= number_to_currency(@booking.total_amount, unit: "₫", separator: ".", delimiter: ",", format: "%n%u", precision: 0) %>
                          </p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <%# Pending notice %>
                <% if @payment&.pending? %>
                  <tr>
                    <td style="padding:16px 24px;background-color:#451a03;border-radius:0 0 12px 12px;">
                      <p style="margin:0 0 4px;font-size:13px;font-weight:600;color:#fde68a;">⚠️ Thanh toán đang chờ xử lý</p>
                      <p style="margin:0;font-size:12px;color:#fcd34d;">
                        Vé sẽ được xác nhận sau khi thanh toán hoàn tất. Ghế đã được tạm giữ cho bạn.
                      </p>
                    </td>
                  </tr>
                <% end %>
              </table>
            </td>
          </tr>

          <%# ── FOOTER ── %>
          <tr>
            <td style="padding:24px 0 8px;text-align:center;">
              <p style="margin:0;font-size:12px;color:#6b7280;">
                Cảm ơn bạn đã đặt vé tại CinemaBooking.<br>
                Vui lòng mang mã đặt vé <strong style="color:#9ca3af;"><%= @booking.booking_code %></strong> khi đến rạp.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
