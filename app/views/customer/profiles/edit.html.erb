<% content_for :title, "Chỉnh sửa hồ sơ" %>

<div class="max-w-5xl mx-auto">
  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-400 mb-6 flex items-center gap-2">
    <%= link_to "Trang chủ", root_path, class: "hover:text-white transition-colors" %>
    <span>/</span>
    <%= link_to "Tài khoản", customer_profile_path, class: "hover:text-white transition-colors" %>
    <span>/</span>
    <span class="text-white">Chỉnh sửa</span>
  </nav>

  <div class="flex flex-col lg:flex-row gap-6">
    <%= render "customer/shared/sidebar" %>

    <!-- Form -->
    <div class="flex-1 min-w-0">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h2 class="text-base font-semibold text-white mb-6">Chỉnh sửa thông tin cá nhân</h2>

        <%= form_with model: @user, url: customer_profile_path, method: :patch, class: "space-y-5" do |f| %>

          <!-- Validation errors -->
          <% if @user.errors.any? %>
            <div class="bg-red-900/30 border border-red-700/50 rounded-lg px-4 py-3">
              <p class="text-sm font-medium text-red-400 mb-1">
                Vui lòng kiểm tra lại (<%= @user.errors.count %> lỗi):
              </p>
              <ul class="list-disc list-inside space-y-0.5">
                <% @user.errors.full_messages.each do |msg| %>
                  <li class="text-sm text-red-300"><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <!-- Name -->
          <div>
            <%= f.label :name, "Họ và tên", class: "block text-sm text-gray-300 mb-1.5" %>
            <%= f.text_field :name,
                  class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-sm text-white
                          placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent
                          transition-colors",
                  placeholder: "Nguyễn Văn A" %>
          </div>

          <!-- Phone -->
          <div>
            <%= f.label :phone, "Số điện thoại", class: "block text-sm text-gray-300 mb-1.5" %>
            <%= f.telephone_field :phone,
                  class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-sm text-white
                          placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent
                          transition-colors",
                  placeholder: "0901 234 567" %>
            <p class="text-xs text-gray-500 mt-1">Để trống nếu không muốn cung cấp.</p>
          </div>

          <!-- Email (read-only, displayed for context) -->
          <div>
            <label class="block text-sm text-gray-300 mb-1.5">Email</label>
            <div class="w-full bg-gray-800/50 border border-gray-700/50 rounded-lg px-4 py-2.5 text-sm text-gray-400 cursor-not-allowed">
              <%= @user.email %>
            </div>
            <p class="text-xs text-gray-500 mt-1">
              Để thay đổi email, vui lòng liên hệ hỗ trợ.
            </p>
          </div>

          <hr class="border-gray-800">

          <!-- Password change hint -->
          <div class="bg-gray-800/40 rounded-lg px-4 py-3 flex items-start gap-3">
            <svg class="w-4 h-4 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-xs text-gray-400">
              Để thay đổi mật khẩu, vui lòng sử dụng
              <%= link_to "trang đổi mật khẩu", edit_user_registration_path,
                    class: "text-red-400 hover:text-red-300 underline underline-offset-2 transition-colors" %>.
            </p>
          </div>

          <!-- Actions -->
          <div class="flex items-center gap-3 pt-2">
            <%= f.submit "Lưu thay đổi",
                  class: "px-6 py-2.5 text-sm font-medium bg-red-600 hover:bg-red-700 text-white rounded-lg
                          transition-colors cursor-pointer" %>
            <%= link_to "Huỷ", customer_profile_path,
                  class: "px-6 py-2.5 text-sm text-gray-400 hover:text-white border border-gray-700
                          hover:border-gray-600 rounded-lg transition-colors" %>
          </div>

        <% end %>
      </div>
    </div>
  </div>
</div>
