<% content_for :title, "Tài khoản của tôi" %>

<div class="max-w-5xl mx-auto">
  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-400 mb-6 flex items-center gap-2">
    <%= link_to "Trang chủ", root_path, class: "hover:text-white transition-colors" %>
    <span>/</span>
    <span class="text-white">Tài khoản</span>
  </nav>

  <div class="flex flex-col lg:flex-row gap-6">
    <%= render "customer/shared/sidebar" %>

    <!-- Main content -->
    <div class="flex-1 min-w-0 space-y-6">

      <!-- Stats cards -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <% [
             { label: "Tổng đặt vé",     value: @stats[:total],                  color: "text-blue-400" },
             { label: "Đã thanh toán",   value: @stats[:paid],                   color: "text-green-400" },
             { label: "Chờ thanh toán",  value: @stats[:pending],                color: "text-yellow-400" },
             { label: "Tổng chi tiêu",   value: format_price(@stats[:spent]),    color: "text-red-400" }
           ].each do |stat| %>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 text-center">
            <p class="text-2xl font-bold <%= stat[:color] %>"><%= stat[:value] %></p>
            <p class="text-xs text-gray-400 mt-1"><%= stat[:label] %></p>
          </div>
        <% end %>
      </div>

      <!-- Profile info -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-base font-semibold text-white">Thông tin cá nhân</h2>
          <%= link_to "Chỉnh sửa", edit_customer_profile_path,
                class: "text-sm text-red-400 hover:text-red-300 transition-colors" %>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <% [
               ["Họ và tên",     @user.name],
               ["Email",         @user.email],
               ["Số điện thoại", @user.phone.presence || "—"],
               ["Vai trò",       "Khách hàng"],
               ["Ngày tham gia", I18n.l(@user.created_at.to_date, format: :long)]
             ].each do |label, value| %>
            <div>
              <p class="text-xs text-gray-500 mb-1"><%= label %></p>
              <p class="text-sm text-white"><%= value %></p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Recent bookings -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-base font-semibold text-white">Đặt vé gần đây</h2>
          <%= link_to "Xem tất cả →", customer_bookings_path,
                class: "text-sm text-red-400 hover:text-red-300 transition-colors" %>
        </div>

        <% if @recent_bookings.any? %>
          <div class="space-y-3">
            <% @recent_bookings.each do |booking| %>
              <% movie    = booking.showtime.movie %>
              <% cinema   = booking.showtime.room.cinema %>
              <% showtime = booking.showtime %>
              <%= link_to customer_booking_path(booking),
                    class: "flex items-center gap-4 p-4 bg-gray-800/50 rounded-lg hover:bg-gray-800 transition-colors group" do %>
                <!-- Movie poster thumbnail -->
                <div class="w-10 h-14 rounded bg-gray-700 shrink-0 overflow-hidden">
                  <% if movie.poster.attached? %>
                    <%= image_tag movie.poster, class: "w-full h-full object-cover" %>
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center text-xs text-gray-500 font-bold">
                      <%= movie.title.first.upcase %>
                    </div>
                  <% end %>
                </div>

                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-white truncate group-hover:text-red-400 transition-colors">
                    <%= movie.title %>
                  </p>
                  <p class="text-xs text-gray-400 mt-0.5">
                    <%= cinema.name %> &bull; <%= I18n.l(showtime.start_time, format: :short) %>
                  </p>
                  <p class="text-xs text-gray-500 mt-0.5">
                    Mã vé: <span class="font-mono text-gray-300"><%= booking.booking_code %></span>
                  </p>
                </div>

                <div class="text-right shrink-0">
                  <%= booking_status_badge(booking.status) %>
                  <p class="text-sm font-semibold text-white mt-1.5">
                    <%= format_price(booking.total_amount) %>
                  </p>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-10 text-gray-500">
            <svg class="w-10 h-10 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
            </svg>
            <p class="text-sm">Bạn chưa có đặt vé nào.</p>
            <%= link_to "Xem phim ngay", movies_path,
                  class: "inline-block mt-3 px-4 py-2 text-sm bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors" %>
          </div>
        <% end %>
      </div>

    </div><!-- /main content -->
  </div>
</div>
