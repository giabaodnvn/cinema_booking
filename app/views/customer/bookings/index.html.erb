<% content_for :title, "Lịch sử đặt vé" %>

<div class="max-w-5xl mx-auto">
  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-400 mb-6 flex items-center gap-2">
    <%= link_to "Trang chủ", root_path, class: "hover:text-white transition-colors" %>
    <span>/</span>
    <%= link_to "Tài khoản", customer_profile_path, class: "hover:text-white transition-colors" %>
    <span>/</span>
    <span class="text-white">Lịch sử đặt vé</span>
  </nav>

  <div class="flex flex-col lg:flex-row gap-6">
    <%= render "customer/shared/sidebar" %>

    <div class="flex-1 min-w-0 space-y-5">

      <!-- Header + filter -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h1 class="text-lg font-semibold text-white">Lịch sử đặt vé</h1>
          <p class="text-sm text-gray-400">
            <%= @pagy.count %> đơn đặt vé
          </p>
        </div>

        <!-- Status filter tabs -->
        <div class="flex items-center gap-1 bg-gray-900 border border-gray-800 rounded-lg p-1 text-sm">
          <% [
               ["Tất cả",          nil],
               ["Đã thanh toán",   "paid"],
               ["Chờ thanh toán",  "pending"],
               ["Đã huỷ",          "cancelled"]
             ].each do |label, status_val| %>
            <%= link_to label,
                  customer_bookings_path(status: status_val),
                  class: "px-3 py-1.5 rounded-md transition-colors #{params[:status].to_s == status_val.to_s ? 'bg-gray-700 text-white font-medium' : 'text-gray-400 hover:text-white'}" %>
          <% end %>
        </div>
      </div>

      <!-- Booking cards -->
      <% if @bookings.any? %>
        <div class="space-y-3">
          <% @bookings.each do |booking| %>
            <% movie    = booking.showtime.movie %>
            <% showtime = booking.showtime %>
            <% cinema   = showtime.room.cinema %>
            <% room     = showtime.room %>

            <%= link_to customer_booking_path(booking),
                  class: "block bg-gray-900 border border-gray-800 rounded-xl p-4 hover:border-gray-600
                          transition-colors group" do %>
              <div class="flex items-start gap-4">

                <!-- Poster -->
                <div class="w-12 h-16 rounded-lg bg-gray-800 shrink-0 overflow-hidden">
                  <% if movie.poster.attached? %>
                    <%= image_tag movie.poster, class: "w-full h-full object-cover" %>
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center text-sm font-bold text-gray-500">
                      <%= movie.title.first.upcase %>
                    </div>
                  <% end %>
                </div>

                <!-- Info -->
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-2 flex-wrap">
                    <h3 class="text-sm font-semibold text-white group-hover:text-red-400 transition-colors truncate">
                      <%= movie.title %>
                    </h3>
                    <%= booking_status_badge(booking.status) %>
                  </div>

                  <div class="mt-1.5 space-y-0.5 text-xs text-gray-400">
                    <p>
                      <span class="text-gray-500">Rạp:</span>
                      <%= cinema.name %> &bull; <%= room_type_label(room.room_type) %>
                    </p>
                    <p>
                      <span class="text-gray-500">Suất chiếu:</span>
                      <%= I18n.l(showtime.start_time, format: :short) %>
                    </p>
                    <p>
                      <span class="text-gray-500">Mã vé:</span>
                      <span class="font-mono text-gray-300"><%= booking.booking_code %></span>
                      &bull;
                      <span class="text-gray-500">Loại:</span>
                      <%= booking_type_label(booking.booking_type) %>
                    </p>
                  </div>
                </div>

                <!-- Amount + arrow -->
                <div class="text-right shrink-0 flex flex-col items-end gap-2">
                  <p class="text-base font-bold text-white">
                    <%= format_price(booking.total_amount) %>
                  </p>
                  <p class="text-xs text-gray-500">
                    <%= I18n.l(booking.created_at.to_date, format: :short) %>
                  </p>
                  <svg class="w-4 h-4 text-gray-600 group-hover:text-gray-400 transition-colors"
                       fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>

              </div>
            <% end %>
          <% end %>
        </div>

        <!-- Pagination -->
        <%= pagy_tailwind_nav(@pagy) %>

      <% else %>
        <div class="bg-gray-900 border border-gray-800 rounded-xl py-16 text-center">
          <svg class="w-12 h-12 mx-auto mb-4 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
          </svg>
          <p class="text-gray-400 mb-4">
            <% if params[:status].present? %>
              Không có đơn đặt vé nào với trạng thái này.
            <% else %>
              Bạn chưa có đơn đặt vé nào.
            <% end %>
          </p>
          <%= link_to "Khám phá phim", movies_path,
                class: "inline-block px-5 py-2.5 text-sm bg-red-600 hover:bg-red-700 text-white
                        rounded-lg transition-colors font-medium" %>
        </div>
      <% end %>

    </div>
  </div>
</div>
