<% content_for :title, "Tất cả phim – CinemaBook" %>

<div class="flex flex-col lg:flex-row gap-8">

  <%# ── SIDEBAR FILTERS ── %>
  <aside class="lg:w-56 flex-shrink-0">
    <%= form_with url: movies_path, method: :get, local: true,
          data: { turbo_frame: "movies_grid" } do |f| %>

      <%# Search %>
      <div class="mb-6">
        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
          Tìm kiếm
        </label>
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500"
               fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <%= f.text_field :q, value: params[:q], placeholder: "Tên phim...",
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg pl-9 pr-3 py-2
                        text-sm text-white placeholder-gray-500 focus:outline-none
                        focus:border-red-500 focus:ring-1 focus:ring-red-500/50" %>
        </div>
      </div>

      <%# Status %>
      <div class="mb-6">
        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
          Trạng thái
        </label>
        <div class="flex flex-col gap-1">
          <%= link_to "Tất cả", movies_path(q: params[:q], genre_id: params[:genre_id], city: params[:city]),
                class: "px-3 py-1.5 rounded-lg text-sm transition-colors #{params[:status].blank? ? 'bg-red-600 text-white font-medium' : 'text-gray-400 hover:bg-gray-800'}" %>
          <%= link_to "Đang chiếu", movies_path(status: "now_showing", q: params[:q], genre_id: params[:genre_id], city: params[:city]),
                class: "px-3 py-1.5 rounded-lg text-sm transition-colors #{params[:status] == 'now_showing' ? 'bg-red-600 text-white font-medium' : 'text-gray-400 hover:bg-gray-800'}" %>
          <%= link_to "Sắp chiếu", movies_path(status: "upcoming", q: params[:q], genre_id: params[:genre_id], city: params[:city]),
                class: "px-3 py-1.5 rounded-lg text-sm transition-colors #{params[:status] == 'upcoming' ? 'bg-blue-600 text-white font-medium' : 'text-gray-400 hover:bg-gray-800'}" %>
        </div>
      </div>

      <%# Genre %>
      <div class="mb-6">
        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
          Thể loại
        </label>
        <div class="flex flex-col gap-1">
          <%= link_to "Tất cả", movies_path(status: params[:status], q: params[:q], city: params[:city]),
                class: "px-3 py-1.5 rounded-lg text-sm transition-colors #{params[:genre_id].blank? ? 'text-white font-medium' : 'text-gray-400 hover:bg-gray-800'}" %>
          <% @genres.each do |genre| %>
            <%= link_to genre.name,
                  movies_path(status: params[:status], q: params[:q], genre_id: genre.id, city: params[:city]),
                  class: "px-3 py-1.5 rounded-lg text-sm transition-colors #{params[:genre_id].to_s == genre.id.to_s ? 'bg-gray-700 text-white font-medium' : 'text-gray-400 hover:bg-gray-800'}" %>
          <% end %>
        </div>
      </div>

      <%# City %>
      <% if @cities.any? %>
      <div class="mb-6">
        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
          Thành phố
        </label>
        <div class="flex flex-col gap-1">
          <%= link_to "Tất cả", movies_path(status: params[:status], q: params[:q], genre_id: params[:genre_id]),
                class: "px-3 py-1.5 rounded-lg text-sm transition-colors #{params[:city].blank? ? 'text-white font-medium' : 'text-gray-400 hover:bg-gray-800'}" %>
          <% @cities.each do |city| %>
            <%= link_to city,
                  movies_path(status: params[:status], q: params[:q], genre_id: params[:genre_id], city: city),
                  class: "px-3 py-1.5 rounded-lg text-sm transition-colors #{params[:city] == city ? 'bg-gray-700 text-white font-medium' : 'text-gray-400 hover:bg-gray-800'}" %>
          <% end %>
        </div>
      </div>
      <% end %>

      <%# Clear filters %>
      <% if params.except(:controller, :action).to_unsafe_h.any? %>
        <%= link_to "Xoá bộ lọc", movies_path,
              class: "w-full block text-center px-3 py-2 text-xs text-gray-500 hover:text-gray-300
                      border border-gray-800 hover:border-gray-600 rounded-lg transition-colors" %>
      <% end %>
    <% end %>
  </aside>

  <%# ── MAIN CONTENT ── %>
  <div class="flex-1 min-w-0">

    <%# Header row %>
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-white">
          <% if params[:status] == "now_showing" %>Đang chiếu
          <% elsif params[:status] == "upcoming" %>Sắp chiếu
          <% else %>Tất cả phim
          <% end %>
        </h1>
        <p class="text-sm text-gray-500 mt-0.5">
          <%= @pagy.count %> phim<% if params[:q].present? %> khớp với "<%= params[:q] %>"<% end %>
        </p>
      </div>
    </div>

    <%# Skeleton shown during Turbo navigation %>
    <template id="skeleton-template">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        <% 8.times do %>
          <div class="bg-gray-900 rounded-xl overflow-hidden border border-gray-800 animate-pulse">
            <div class="aspect-[2/3] bg-gray-800"></div>
            <div class="p-3 space-y-2">
              <div class="h-4 bg-gray-700 rounded w-3/4"></div>
              <div class="h-3 bg-gray-800 rounded w-1/2"></div>
            </div>
          </div>
        <% end %>
      </div>
    </template>

    <%# Movies grid %>
    <% if @movies.any? %>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        <% @movies.each do |movie| %>
          <%= render "movie_card", movie: movie %>
        <% end %>
      </div>

      <%# Pagination %>
      <%= pagy_tailwind_nav(@pagy) %>

    <% else %>
      <div class="text-center py-20">
        <div class="text-6xl mb-4">🎬</div>
        <h3 class="text-lg font-semibold text-gray-400 mb-2">Không tìm thấy phim</h3>
        <p class="text-sm text-gray-600">Thử thay đổi bộ lọc hoặc từ khoá tìm kiếm.</p>
        <%= link_to "Xem tất cả phim", movies_path, class: "mt-4 inline-block text-sm text-red-400 hover:text-red-300" %>
      </div>
    <% end %>
  </div>

</div>
