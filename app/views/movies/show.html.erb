<% content_for :title, "#{@movie.title} – CinemaBook" %>

<%# ── BREADCRUMB ── %>
<nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
  <%= link_to "Trang chủ", root_path, class: "hover:text-gray-300 transition-colors" %>
  <span>›</span>
  <%= link_to "Phim", movies_path, class: "hover:text-gray-300 transition-colors" %>
  <span>›</span>
  <span class="text-gray-300 truncate max-w-48"><%= @movie.title %></span>
</nav>

<%# ── MOVIE HEADER ── %>
<div class="flex flex-col md:flex-row gap-8 mb-10">

  <%# Poster %>
  <div class="md:w-64 lg:w-72 flex-shrink-0">
    <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-black/60
                aspect-[2/3] bg-gray-800">
      <% if @movie.poster.attached? %>
        <%= image_tag url_for(@movie.poster),
              class: "w-full h-full object-cover", alt: @movie.title %>
      <% else %>
        <div class="w-full h-full flex items-center justify-center
                    bg-gradient-to-br from-gray-700 via-gray-800 to-gray-900">
          <span class="text-9xl font-black text-gray-600 select-none">
            <%= @movie.title[0] %>
          </span>
        </div>
      <% end %>

      <%# Status overlay %>
      <div class="absolute top-3 left-3">
        <% if @movie.now_showing? %>
          <span class="bg-red-600 text-white text-xs font-bold px-2.5 py-1 rounded-lg shadow-lg">
            ĐANG CHIẾU
          </span>
        <% elsif @movie.upcoming? %>
          <span class="bg-blue-600 text-white text-xs font-bold px-2.5 py-1 rounded-lg shadow-lg">
            SẮP CHIẾU
          </span>
        <% end %>
      </div>
    </div>
  </div>

  <%# Info panel %>
  <div class="flex-1 min-w-0">
    <h1 class="text-3xl lg:text-4xl font-black text-white leading-tight mb-3">
      <%= @movie.title %>
    </h1>

    <%# Meta pills %>
    <div class="flex flex-wrap gap-2 mb-5">
      <%= age_rating_badge(@movie.age_rating) %>
      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs
                   bg-gray-800 text-gray-300 border border-gray-700">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        <%= format_duration(@movie.duration) %>
      </span>
      <% if @movie.release_date.present? %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs
                     bg-gray-800 text-gray-300 border border-gray-700">
          <%= @movie.release_date.strftime("%d/%m/%Y") %>
        </span>
      <% end %>
      <% @movie.genres.each do |genre| %>
        <%= link_to genre.name, movies_path(genre_id: genre.id),
              class: "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs
                      bg-gray-800 text-gray-400 border border-gray-700
                      hover:border-gray-500 hover:text-white transition-colors" %>
      <% end %>
    </div>

    <%# Description %>
    <% if @movie.description.present? %>
      <p class="text-gray-300 leading-relaxed mb-6 max-w-2xl text-[15px]">
        <%= @movie.description %>
      </p>
    <% end %>

    <%# CTA %>
    <% if @movie.now_showing? && @showtimes_by_date.any? %>
      <a href="#showtimes"
         class="inline-flex items-center gap-2 px-6 py-3 bg-red-600 hover:bg-red-700
                rounded-xl font-semibold transition-colors shadow-lg shadow-red-900/40">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
        </svg>
        Chọn suất chiếu
      </a>
    <% end %>
  </div>
</div>

<%# ── TRAILER ── %>
<% embed_url = youtube_embed_url(@movie.trailer_url) %>
<% if embed_url %>
<section class="mb-10">
  <h2 class="text-xl font-bold text-white mb-4">Trailer</h2>
  <div class="relative aspect-video rounded-2xl overflow-hidden bg-gray-900 border border-gray-800
              max-w-3xl shadow-2xl shadow-black/60">
    <iframe src="<%= embed_url %>?rel=0&modestbranding=1"
            class="absolute inset-0 w-full h-full"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            title="<%= @movie.title %> trailer">
    </iframe>
  </div>
</section>
<% end %>

<%# ── SHOWTIMES ── %>
<section id="showtimes" class="scroll-mt-20">
  <h2 class="text-xl font-bold text-white mb-6">Lịch chiếu</h2>

  <% if @showtimes_by_date.any? %>
    <div class="space-y-6">
      <% @showtimes_by_date.each do |date, day_showtimes| %>
        <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">

          <%# Date header %>
          <div class="px-5 py-3 bg-gray-800/60 border-b border-gray-700/60">
            <div class="flex items-center gap-3">
              <div class="text-center min-w-[40px]">
                <div class="text-2xl font-black text-white leading-none">
                  <%= date.strftime("%d") %>
                </div>
                <div class="text-xs text-gray-500 uppercase">
                  Th.<%= date.strftime("%-m") %>
                </div>
              </div>
              <div>
                <div class="text-sm font-semibold text-white">
                  <%= I18n.l(date, format: "%A") rescue date.strftime("%A") %>
                </div>
                <div class="text-xs text-gray-500">
                  <%= day_showtimes.size %> suất chiếu tại <%= day_showtimes.map { |s| s.room.cinema.name }.uniq.count %> rạp
                </div>
              </div>
            </div>
          </div>

          <%# Group by cinema within this date %>
          <div class="divide-y divide-gray-800/60">
            <% day_showtimes.group_by { |s| s.room.cinema }.each do |cinema, cinema_showtimes| %>
              <div class="px-5 py-4">
                <div class="flex items-center gap-2 mb-3">
                  <svg class="w-4 h-4 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  </svg>
                  <span class="text-sm font-semibold text-gray-300"><%= cinema.name %></span>
                  <span class="text-xs text-gray-600"><%= cinema.city %></span>
                </div>

                <div class="flex flex-wrap gap-2">
                  <% cinema_showtimes.sort_by(&:start_time).each do |showtime| %>
                    <% booked   = @booked_counts[showtime.id] || 0 %>
                    <% capacity = showtime.room.capacity %>
                    <% available = capacity - booked %>
                    <% sold_out  = available <= 0 %>
                    <% almost    = available > 0 && available <= (capacity * 0.2).ceil %>

                    <div class="border rounded-xl px-3 py-2 min-w-[110px] text-center
                                <%= sold_out ? 'border-gray-800 bg-gray-800/30 opacity-50 cursor-not-allowed' :
                                    'border-gray-700 bg-gray-800/50 hover:border-red-500 hover:bg-gray-800 cursor-pointer transition-all' %>">

                      <div class="text-base font-bold <%= sold_out ? 'text-gray-500' : 'text-white' %>">
                        <%= showtime.start_time.strftime("%H:%M") %>
                      </div>
                      <div class="text-xs text-gray-500 mt-0.5">
                        ~ <%= showtime.end_time.strftime("%H:%M") %>
                      </div>
                      <div class="mt-1.5 flex items-center justify-center gap-1">
                        <span class="text-xs font-medium
                                     <%= showtime.room.room_type == 'imax' ? 'text-purple-400' :
                                         showtime.room.room_type == 'vip'  ? 'text-yellow-400' : 'text-gray-400' %>">
                          <%= room_type_label(showtime.room.room_type) %>
                        </span>
                      </div>
                      <div class="mt-1.5 text-xs font-semibold
                                  <%= sold_out ? 'text-gray-600' : almost ? 'text-orange-400' : 'text-red-400' %>">
                        <% if sold_out %>
                          Hết vé
                        <% elsif almost %>
                          Còn <%= available %> chỗ
                        <% else %>
                          <%= format_price(showtime.price) %>
                        <% end %>
                      </div>

                      <% unless sold_out %>
                        <% seat_path = (user_signed_in? && current_user.customer?) \
                                         ? showtime_seats_path(showtime) \
                                         : new_user_session_path %>
                        <%= link_to "Chọn ghế", seat_path,
                              class: "mt-2 block text-xs bg-red-600 hover:bg-red-700 text-white
                                      rounded-lg py-1 transition-colors font-medium" %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

  <% else %>
    <div class="text-center py-12 bg-gray-900 rounded-2xl border border-gray-800">
      <div class="text-4xl mb-3">🎭</div>
      <p class="text-gray-400 font-medium">Chưa có lịch chiếu</p>
      <p class="text-sm text-gray-600 mt-1">Vui lòng quay lại sau.</p>
    </div>
  <% end %>
</section>
