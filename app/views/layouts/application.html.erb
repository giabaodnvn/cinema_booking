<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <title><%= content_for(:title) || "Cinema Booking" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-gray-950 text-white flex flex-col">

    <!-- HEADER / NAVBAR -->
    <header class="bg-gray-900 border-b border-gray-800 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

          <!-- Logo -->
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-red-600 flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18 4l2 4h-3l-2-4h-2l2 4h-3l-2-4H8l2 4H7L5 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V4h-4z"/>
              </svg>
            </div>
            <%= link_to "CinemaBook", root_path, class: "text-xl font-bold text-white hover:text-red-400 transition-colors" %>
          </div>

          <!-- Nav Links -->
          <nav class="hidden md:flex items-center gap-6">
            <%= link_to "Phim", movies_path,
                  class: "text-sm hover:text-white transition-colors #{request.path.start_with?(movies_path) ? 'text-white font-medium' : 'text-gray-300'}" %>
            <%= link_to "Rạp chiếu", cinemas_path,
                  class: "text-sm hover:text-white transition-colors #{request.path.start_with?(cinemas_path) ? 'text-white font-medium' : 'text-gray-300'}" %>
            <%= link_to "Lịch chiếu", showtimes_path,
                  class: "text-sm hover:text-white transition-colors #{current_page?(showtimes_path) ? 'text-white font-medium' : 'text-gray-300'}" %>
          </nav>

          <!-- Auth -->
          <div class="flex items-center gap-3">
            <% if user_signed_in? %>
              <% if current_user.can_access_admin? %>
                <%= link_to "Admin", admin_root_path, class: "text-sm text-yellow-400 hover:text-yellow-300 transition-colors" %>
              <% elsif current_user.can_access_staff? %>
                <%= link_to "Staff", staff_root_path, class: "text-sm text-blue-400 hover:text-blue-300 transition-colors" %>
              <% end %>

              <!-- Customer account dropdown -->
              <div class="relative" data-controller="dropdown">
                <button data-action="click->dropdown#toggle click@window->dropdown#hide"
                        class="flex items-center gap-2 px-3 py-1.5 text-sm text-gray-300 hover:text-white
                               border border-gray-700 hover:border-gray-500 rounded-lg transition-colors">
                  <div class="w-6 h-6 rounded-full bg-red-600 flex items-center justify-center text-xs font-bold text-white shrink-0">
                    <%= current_user.name.first.upcase %>
                  </div>
                  <span class="hidden sm:block truncate max-w-24"><%= current_user.name %></span>
                  <svg class="w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>

                <div data-dropdown-target="menu"
                     class="hidden absolute right-0 mt-2 w-48 bg-gray-900 border border-gray-700 rounded-xl
                            shadow-xl z-50 overflow-hidden">
                  <% if current_user.customer? %>
                    <%= link_to customer_profile_path,
                          class: "flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-300 hover:text-white hover:bg-gray-800 transition-colors" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                      </svg>
                      Tài khoản
                    <% end %>
                    <%= link_to customer_bookings_path,
                          class: "flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-300 hover:text-white hover:bg-gray-800 transition-colors" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                      </svg>
                      Lịch sử đặt vé
                    <% end %>
                    <div class="border-t border-gray-800 my-1"></div>
                  <% end %>
                  <%= link_to destroy_user_session_path, data: { turbo_method: :delete },
                        class: "flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-400 hover:text-red-400 hover:bg-gray-800 transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                    Đăng xuất
                  <% end %>
                </div>
              </div>
            <% else %>
              <%= link_to "Sign in", new_user_session_path,
                  class: "text-sm text-gray-300 hover:text-white transition-colors" %>
              <%= link_to "Sign up", new_user_registration_path,
                  class: "px-4 py-2 text-sm bg-red-600 rounded-lg hover:bg-red-700 transition-colors font-medium" %>
            <% end %>
          </div>

        </div>
      </div>
    </header>

    <!-- Flash data for SweetAlert2 -->
    <div id="flash-data" class="hidden"
         data-notice="<%= h notice.to_s %>"
         data-alert="<%= h alert.to_s %>"></div>

    <!-- MAIN CONTENT -->
    <main class="flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <!-- FOOTER -->
    <footer class="bg-gray-900 border-t border-gray-800 mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded bg-red-600 flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18 4l2 4h-3l-2-4h-2l2 4h-3l-2-4H8l2 4H7L5 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V4h-4z"/>
              </svg>
            </div>
            <span class="text-sm font-semibold text-white">CinemaBook</span>
          </div>
          <p class="text-xs text-gray-500">
            &copy; <%= Date.current.year %> CinemaBook. All rights reserved.
          </p>
          <div class="flex gap-4 text-xs text-gray-500">
            <%= link_to "Privacy", "#", class: "hover:text-gray-300 transition-colors" %>
            <%= link_to "Terms", "#", class: "hover:text-gray-300 transition-colors" %>
            <%= link_to "Contact", "#", class: "hover:text-gray-300 transition-colors" %>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>
