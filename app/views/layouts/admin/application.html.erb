<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <title><%= content_for(:title) || "Admin – CinemaBook" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-gray-950 text-white flex">

    <!-- Sidebar -->
    <aside class="w-64 flex-shrink-0 bg-gray-900 border-r border-gray-800 flex flex-col">
      <div class="h-16 flex items-center gap-3 px-5 border-b border-gray-800">
        <div class="w-7 h-7 rounded bg-yellow-500 flex items-center justify-center">
          <svg class="w-4 h-4 text-gray-900" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <span class="font-bold text-white">Admin Panel</span>
      </div>

      <nav class="flex-1 overflow-y-auto py-4 px-3">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-2 mb-2">Overview</p>
        <%= link_to admin_root_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm mb-1 #{current_page?(admin_root_path) ? 'bg-yellow-500/20 text-yellow-400' : 'text-gray-400 hover:bg-gray-800 hover:text-white'} transition-colors" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Dashboard
        <% end %>

        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-2 mb-2 mt-4">Management</p>

        <% nav_items = [
             { label: "Người dùng",  path: admin_users_path,     icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" },
             { label: "Phim",        path: admin_movies_path,    icon: "M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" },
             { label: "Thể loại",    path: admin_genres_path,    icon: "M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" },
             { label: "Rạp chiếu",   path: admin_cinemas_path,   icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" },
             { label: "Suất chiếu",  path: admin_showtimes_path, icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
             { label: "Đặt vé",      path: admin_bookings_path,  icon: "M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" },
             { label: "Báo cáo",     path: admin_reports_path,   icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" }
           ] %>

        <% nav_items.each do |item| %>
          <% active = request.path.start_with?(item[:path]) %>
          <%= link_to item[:path],
                class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm mb-1 transition-colors
                        #{active ? 'bg-yellow-500/20 text-yellow-400' : 'text-gray-400 hover:bg-gray-800 hover:text-white'}" do %>
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item[:icon] %>"/>
            </svg>
            <%= item[:label] %>
          <% end %>
        <% end %>
      </nav>

      <div class="p-4 border-t border-gray-800">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-8 h-8 rounded-full bg-yellow-500/20 border border-yellow-500/40 flex items-center justify-center text-sm font-bold text-yellow-400">
            <%= current_user.name[0].upcase %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-white truncate"><%= current_user.name %></p>
            <p class="text-xs text-yellow-400">Admin</p>
          </div>
        </div>
        <%= link_to "Back to Site", root_path, class: "block text-xs text-center text-gray-400 hover:text-white transition-colors mb-1" %>
        <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "block text-xs text-center text-red-400 hover:text-red-300 transition-colors" %>
      </div>
    </aside>

    <!-- Main -->
    <div class="flex-1 flex flex-col min-w-0">
      <!-- Top bar -->
      <header class="h-16 bg-gray-900 border-b border-gray-800 flex items-center justify-between px-6">
        <h1 class="text-lg font-semibold text-white"><%= content_for(:page_title) { "Dashboard" } %></h1>
        <div class="flex items-center gap-2 text-sm text-gray-400">
          <span class="w-2 h-2 rounded-full bg-green-400"></span>
          <%= current_user.email %>
        </div>
      </header>

      <!-- Flash data for SweetAlert2 -->
      <div id="flash-data" class="hidden"
           data-notice="<%= h notice.to_s %>"
           data-alert="<%= h alert.to_s %>"></div>

      <main class="flex-1 overflow-y-auto p-6">
        <%= yield %>
      </main>
    </div>

  </body>
</html>
