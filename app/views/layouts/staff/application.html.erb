<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <title><%= content_for(:title) || "Staff – CinemaBook" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-gray-950 text-white flex flex-col">

    <!-- Staff Topbar -->
    <header class="bg-gray-900 border-b border-gray-800">
      <div class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded bg-blue-600 flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M18 4l2 4h-3l-2-4h-2l2 4h-3l-2-4H8l2 4H7L5 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V4h-4z"/></svg>
            </div>
            <span class="font-bold text-white text-sm">Staff Counter</span>
          </div>

          <nav class="flex items-center gap-1">
            <%= link_to "Dashboard", staff_root_path,
                  class: "px-3 py-1.5 rounded-lg text-sm transition-colors #{current_page?(staff_root_path) ? 'bg-blue-600/20 text-blue-400' : 'text-gray-400 hover:text-white hover:bg-gray-800'}" %>
            <%= link_to "Đặt vé mới", new_staff_booking_path,
                  class: "px-3 py-1.5 rounded-lg text-sm transition-colors #{current_page?(new_staff_booking_path) ? 'bg-blue-600/20 text-blue-400' : 'text-gray-400 hover:text-white hover:bg-gray-800'}" %>
            <%= link_to "Danh sách vé", staff_bookings_path,
                  class: "px-3 py-1.5 rounded-lg text-sm transition-colors #{request.path.start_with?(staff_bookings_path) && !current_page?(new_staff_booking_path) ? 'bg-blue-600/20 text-blue-400' : 'text-gray-400 hover:text-white hover:bg-gray-800'}" %>
          </nav>
        </div>

        <div class="flex items-center gap-3">
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-full bg-blue-600/20 border border-blue-500/40 flex items-center justify-center text-xs font-bold text-blue-400">
              <%= current_user.name[0].upcase %>
            </div>
            <span class="text-sm text-gray-300"><%= current_user.name %></span>
            <span class="px-1.5 py-0.5 rounded text-xs bg-blue-500/20 text-blue-400 font-medium">
              <%= current_user.role.capitalize %>
            </span>
          </div>
          <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-xs text-gray-400 hover:text-red-400 transition-colors" %>
        </div>
      </div>
    </header>

    <!-- Flash -->
    <% if notice.present? %>
      <div class="bg-green-800/80 border-b border-green-700 text-green-200 px-4 py-2 text-sm text-center"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="bg-red-800/80 border-b border-red-700 text-red-200 px-4 py-2 text-sm text-center"><%= alert %></div>
    <% end %>

    <main class="flex-1 max-w-7xl w-full mx-auto px-4 py-6">
      <%= yield %>
    </main>

  </body>
</html>
