<% content_for :title, "Đặt vé thành công – #{@booking.booking_code}" %>

<% movie    = @booking.showtime.movie %>
<% showtime = @booking.showtime %>
<% room     = showtime.room %>
<% cinema   = room.cinema %>

<div class="max-w-2xl mx-auto py-4">

  <%# ── SUCCESS HEADER ── %>
  <div class="text-center mb-8">
    <div class="w-16 h-16 rounded-full bg-green-500/20 border-2 border-green-500/40 flex items-center
                justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
      </svg>
    </div>
    <h1 class="text-2xl font-bold text-white mb-2">Đặt vé thành công!</h1>
    <p class="text-gray-400 text-sm">
      Mã đặt vé của bạn là
      <span class="font-mono font-bold text-white text-base"><%= @booking.booking_code %></span>
    </p>
  </div>

  <%# ── TICKET CARD ── %>
  <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden mb-6">

    <%# Movie header %>
    <div class="bg-gray-800/60 px-6 py-5 flex items-center gap-5">
      <div class="w-14 h-20 rounded-lg bg-gray-700 shrink-0 overflow-hidden">
        <% if movie.poster.attached? %>
          <%= image_tag movie.poster, class: "w-full h-full object-cover" %>
        <% else %>
          <div class="w-full h-full flex items-center justify-center text-xl font-bold text-gray-500">
            <%= movie.title.first.upcase %>
          </div>
        <% end %>
      </div>
      <div>
        <p class="text-lg font-bold text-white leading-tight"><%= movie.title %></p>
        <div class="flex items-center gap-2 mt-1.5 flex-wrap">
          <%= age_rating_badge(movie.age_rating) %>
          <span class="text-xs text-gray-400"><%= format_duration(movie.duration) %></span>
        </div>
      </div>
    </div>

    <%# Dotted separator ── ticket perforation ── %>
    <div class="flex items-center px-6">
      <div class="w-4 h-4 rounded-full bg-gray-950 -ml-10 shrink-0"></div>
      <div class="flex-1 border-t-2 border-dashed border-gray-700 mx-2"></div>
      <div class="w-4 h-4 rounded-full bg-gray-950 -mr-10 shrink-0"></div>
    </div>

    <%# Showtime details %>
    <div class="px-6 py-5 grid grid-cols-2 gap-x-6 gap-y-4">
      <% [
           ["Rạp chiếu",    cinema.name],
           ["Phòng",        "#{room.name} (#{room_type_label(room.room_type)})"],
           ["Ngày chiếu",   I18n.l(showtime.start_time.to_date, format: :long)],
           ["Suất chiếu",   "#{I18n.l(showtime.start_time, format: :time)} – #{I18n.l(showtime.end_time, format: :time)}"]
         ].each do |label, value| %>
        <div>
          <p class="text-xs text-gray-500 mb-0.5"><%= label %></p>
          <p class="text-sm text-white font-medium"><%= value %></p>
        </div>
      <% end %>
    </div>

    <%# Seats %>
    <div class="px-6 pb-5">
      <p class="text-xs text-gray-500 mb-2">Ghế ngồi</p>
      <div class="flex flex-wrap gap-2">
        <% @booking.booking_seats.each do |bs| %>
          <div class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-center min-w-14">
            <p class="text-sm font-bold text-white font-mono"><%= bs.seat.label %></p>
            <p class="text-xs text-gray-500 capitalize"><%= bs.seat.seat_type %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# Dotted separator %>
    <div class="flex items-center px-6">
      <div class="w-4 h-4 rounded-full bg-gray-950 -ml-10 shrink-0"></div>
      <div class="flex-1 border-t-2 border-dashed border-gray-700 mx-2"></div>
      <div class="w-4 h-4 rounded-full bg-gray-950 -mr-10 shrink-0"></div>
    </div>

    <%# Payment summary %>
    <div class="px-6 py-5 flex items-center justify-between">
      <div>
        <p class="text-xs text-gray-500 mb-0.5">Trạng thái thanh toán</p>
        <% if @booking.payment&.pending? %>
          <span class="inline-flex items-center gap-1.5 text-sm font-medium text-yellow-400">
            <span class="w-2 h-2 rounded-full bg-yellow-400 animate-pulse"></span>
            Chờ thanh toán
          </span>
        <% elsif @booking.payment&.completed? %>
          <span class="inline-flex items-center gap-1.5 text-sm font-medium text-green-400">
            <span class="w-2 h-2 rounded-full bg-green-400"></span>
            Đã thanh toán
          </span>
        <% end %>
      </div>
      <div class="text-right">
        <p class="text-xs text-gray-500 mb-0.5">Tổng tiền</p>
        <p class="text-2xl font-bold text-white"><%= format_price(@booking.total_amount) %></p>
      </div>
    </div>
  </div>

  <%# ── PAYMENT NOTICE (if pending) ── %>
  <% if @booking.payment&.pending? %>
    <div class="bg-yellow-900/20 border border-yellow-800/40 rounded-xl px-5 py-4 mb-6 flex items-start gap-3">
      <svg class="w-5 h-5 text-yellow-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <div>
        <p class="text-sm font-medium text-yellow-300">Thanh toán đang chờ xử lý</p>
        <p class="text-xs text-yellow-400/80 mt-0.5">
          Vé sẽ được xác nhận sau khi thanh toán hoàn tất. Ghế đã được tạm giữ cho bạn.
          <br>Phương thức: <span class="font-medium"><%= payment_method_label(@booking.payment.method) %></span>
        </p>
      </div>
    </div>
  <% end %>

  <%# ── ACTIONS ── %>
  <div class="flex flex-col sm:flex-row gap-3">
    <%= link_to customer_booking_path(@booking),
          class: "flex-1 flex items-center justify-center gap-2 py-3 text-sm font-medium
                  bg-red-600 hover:bg-red-700 text-white rounded-xl transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
      </svg>
      Xem chi tiết vé
    <% end %>
    <%= link_to movies_path,
          class: "flex-1 flex items-center justify-center gap-2 py-3 text-sm font-medium
                  border border-gray-700 hover:border-gray-500 text-gray-300 hover:text-white
                  rounded-xl transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
      </svg>
      Xem phim khác
    <% end %>
  </div>

</div>
