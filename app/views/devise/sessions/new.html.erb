<div class="min-h-screen flex items-center justify-center py-12 px-4">
  <div class="w-full max-w-sm">
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-red-600 mb-4">
        <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18 4l2 4h-3l-2-4h-2l2 4h-3l-2-4H8l2 4H7L5 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V4h-4z"/>
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-white">Sign in to CinemaBook</h1>
      <p class="text-sm text-gray-400 mt-1">Welcome back!</p>
    </div>

    <div class="bg-gray-900 rounded-2xl border border-gray-800 p-6">
      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-300 mb-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent",
                placeholder: "you@example.com" %>
          </div>

          <div>
            <div class="flex items-center justify-between mb-1">
              <%= f.label :password, class: "text-sm font-medium text-gray-300" %>
              <% if devise_mapping.recoverable? %>
                <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-xs text-red-400 hover:text-red-300" %>
              <% end %>
            </div>
            <%= f.password_field :password, autocomplete: "current-password",
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent",
                placeholder: "••••••••" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "w-4 h-4 rounded border-gray-600 bg-gray-800 text-red-500 focus:ring-red-500" %>
              <%= f.label :remember_me, class: "text-sm text-gray-400" %>
            </div>
          <% end %>

          <%= f.submit "Sign in", class: "w-full bg-red-600 hover:bg-red-700 text-white font-medium py-2.5 px-4 rounded-lg transition-colors cursor-pointer mt-2" %>
        </div>
      <% end %>
    </div>

    <p class="text-center text-sm text-gray-400 mt-6">
      Don't have an account?
      <%= link_to "Sign up", new_registration_path(resource_name), class: "text-red-400 hover:text-red-300 font-medium" %>
    </p>
  </div>
</div>
