<div class="space-y-4">
  <div>
    <label class="block text-xs text-gray-400 mb-1">Tên phòng <span class="text-red-400">*</span></label>
    <%= f.text_field :name, placeholder: "VD: Phòng 1, IMAX 1…",
          class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white
                  focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500" %>
  </div>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <label class="block text-xs text-gray-400 mb-1">Sức chứa <span class="text-red-400">*</span></label>
      <%= f.number_field :capacity, min: 1,
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white
                    focus:outline-none focus:border-yellow-500" %>
    </div>
    <div>
      <label class="block text-xs text-gray-400 mb-1">Loại phòng</label>
      <%= f.select :room_type,
            [["Standard", "standard"], ["VIP", "vip"], ["IMAX", "imax"], ["Couple", "couple"]], {},
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white
                    focus:outline-none focus:border-yellow-500" %>
    </div>
  </div>
</div>
