<% content_for :page_title, @cinema.name %>

<div class="max-w-5xl">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3 text-sm text-gray-400">
      <%= link_to "← Rạp chiếu", admin_cinemas_path, class: "hover:text-white" %>
      <span>/</span>
      <span class="text-gray-300 truncate max-w-52"><%= @cinema.name %></span>
    </div>
    <div class="flex gap-2">
      <%= link_to "Sửa", edit_admin_cinema_path(@cinema),
            class: "px-4 py-2 bg-yellow-500/20 hover:bg-yellow-500/30 text-yellow-400 text-sm font-medium rounded-lg transition-colors" %>
      <%= link_to "Xoá", admin_cinema_path(@cinema),
            data: { turbo_method: :delete, turbo_confirm: "Xoá rạp '#{@cinema.name}'?" },
            class: "px-4 py-2 bg-red-600/20 hover:bg-red-600/30 text-red-400 text-sm rounded-lg border border-red-600/30 transition-colors" %>
    </div>
  </div>

  <%# Cinema info %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-5">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
      <% [["Thành phố", @cinema.city], ["Địa chỉ", @cinema.address],
           ["SĐT", @cinema.phone.presence || "—"],
           ["Trạng thái", @cinema.active? ? "Hoạt động" : "Tạm dừng"]].each do |label, val| %>
        <div>
          <p class="text-xs text-gray-500 mb-0.5"><%= label %></p>
          <p class="text-gray-300"><%= val %></p>
        </div>
      <% end %>
    </div>
  </div>

  <%# Rooms list %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl">
    <div class="px-5 py-4 border-b border-gray-800 flex items-center justify-between">
      <p class="text-sm font-semibold text-white">Phòng chiếu (<%= @rooms.count %>)</p>
      <%= link_to "＋ Thêm phòng", new_admin_cinema_room_path(@cinema),
            class: "text-xs px-3 py-1.5 bg-yellow-500/20 hover:bg-yellow-500/30 text-yellow-400 rounded-lg transition-colors" %>
    </div>

    <% if @rooms.empty? %>
      <div class="px-5 py-10 text-center text-gray-600 text-sm">Chưa có phòng chiếu nào.</div>
    <% else %>
      <div class="divide-y divide-gray-800">
        <% @rooms.each do |room| %>
          <div class="px-5 py-4 flex items-center justify-between hover:bg-gray-800/30 transition-colors">
            <div>
              <p class="font-medium text-white"><%= room.name %></p>
              <p class="text-xs text-gray-400 mt-0.5">
                <%= room_type_label(room.room_type) %>
                &bull; <%= room.capacity %> ghế
                &bull; <%= room.seats.count %> ghế đã tạo
              </p>
            </div>
            <div class="flex items-center gap-3">
              <%= link_to "Quản lý ghế", admin_room_path(room),
                    class: "text-xs px-3 py-1.5 bg-gray-700 hover:bg-gray-600 text-gray-300 hover:text-white rounded-lg transition-colors" %>
              <%= link_to "Sửa", edit_admin_room_path(room),
                    class: "text-xs px-3 py-1.5 bg-yellow-500/20 hover:bg-yellow-500/30 text-yellow-400 rounded-lg transition-colors" %>
              <%= link_to "Xoá", admin_room_path(room),
                    data: { turbo_method: :delete, turbo_confirm: "Xoá phòng '#{room.name}'?" },
                    class: "text-xs px-3 py-1.5 bg-red-600/20 hover:bg-red-600/30 text-red-400 rounded-lg border border-red-600/30 transition-colors" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
