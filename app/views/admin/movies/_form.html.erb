<%# Shared form for new/edit movie. Expects: @movie, @genres, f (form builder) %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <%# ── LEFT: Main info ── %>
  <div class="lg:col-span-2 space-y-4">

    <div>
      <label class="block text-xs text-gray-400 mb-1">Tên phim <span class="text-red-400">*</span></label>
      <%= f.text_field :title,
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white
                    focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500",
            placeholder: "Ví dụ: Avengers: Endgame" %>
    </div>

    <div>
      <label class="block text-xs text-gray-400 mb-1">Mô tả</label>
      <%= f.text_area :description, rows: 4,
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white
                    focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500 resize-y",
            placeholder: "Nội dung phim…" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-xs text-gray-400 mb-1">Thời lượng (phút) <span class="text-red-400">*</span></label>
        <%= f.number_field :duration, min: 1,
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white
                      focus:outline-none focus:border-yellow-500" %>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-1">Ngày khởi chiếu</label>
        <%= f.date_field :release_date,
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white
                      focus:outline-none focus:border-yellow-500" %>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-xs text-gray-400 mb-1">Trạng thái</label>
        <%= f.select :status,
              [["Nháp", "draft"], ["Sắp chiếu", "upcoming"],
               ["Đang chiếu", "now_showing"], ["Đã kết thúc", "ended"]],
              {},
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white
                      focus:outline-none focus:border-yellow-500" %>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-1">Phân loại tuổi</label>
        <%= f.select :age_rating,
              [["— Chưa chọn —", ""], ["P – Mọi lứa tuổi", "P"], ["T13 – Từ 13 tuổi", "T13"],
               ["T16 – Từ 16 tuổi", "T16"], ["T18 – Từ 18 tuổi", "T18"]],
              {},
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white
                      focus:outline-none focus:border-yellow-500" %>
      </div>
    </div>

    <div>
      <label class="block text-xs text-gray-400 mb-1">Trailer URL (YouTube)</label>
      <%= f.url_field :trailer_url,
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white
                    focus:outline-none focus:border-yellow-500",
            placeholder: "https://www.youtube.com/watch?v=..." %>
    </div>

    <%# Genres checkboxes %>
    <div>
      <label class="block text-xs text-gray-400 mb-2">Thể loại</label>
      <div class="flex flex-wrap gap-2">
        <% @genres.each do |genre| %>
          <label class="flex items-center gap-1.5 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2
                         cursor-pointer hover:border-yellow-600 has-[:checked]:border-yellow-500
                         has-[:checked]:bg-yellow-500/10 transition-colors">
            <%= check_box_tag "movie[genre_ids][]", genre.id,
                  @movie.genre_ids.include?(genre.id),
                  id: "genre_#{genre.id}",
                  class: "accent-yellow-500" %>
            <span class="text-sm text-gray-300"><%= genre.name %></span>
          </label>
        <% end %>
        <% if @genres.empty? %>
          <p class="text-sm text-gray-500">Chưa có thể loại. <%= link_to "Tạo thể loại", admin_genres_path, class: "text-yellow-400 underline" %></p>
        <% end %>
      </div>
      <%# Hidden field so empty selection clears genres %>
      <%= hidden_field_tag "movie[genre_ids][]", "" %>
    </div>
  </div>

  <%# ── RIGHT: Poster ── %>
  <div class="space-y-4">
    <div>
      <label class="block text-xs text-gray-400 mb-2">Poster phim</label>

      <%# Current poster preview %>
      <% if @movie.poster.attached? %>
        <div class="mb-3">
          <%= image_tag @movie.poster,
                class: "w-full max-w-48 aspect-[2/3] object-cover rounded-xl border border-gray-700" %>
          <p class="text-xs text-gray-500 mt-1">Poster hiện tại</p>
        </div>
      <% else %>
        <div class="w-full max-w-48 aspect-[2/3] bg-gray-800 border border-dashed border-gray-700
                    rounded-xl flex items-center justify-center mb-3">
          <p class="text-xs text-gray-600 text-center px-3">Chưa có poster</p>
        </div>
      <% end %>

      <%= f.file_field :poster, accept: "image/*",
            class: "w-full text-sm text-gray-400 file:mr-3 file:py-1.5 file:px-3
                    file:rounded-lg file:border-0 file:text-xs file:font-medium
                    file:bg-yellow-500/20 file:text-yellow-400 hover:file:bg-yellow-500/30" %>
      <p class="text-xs text-gray-600 mt-1">JPG, PNG, WebP. Khuyến nghị 2:3.</p>
    </div>
  </div>
</div>
