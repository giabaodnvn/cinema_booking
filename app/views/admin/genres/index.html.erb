<% content_for :page_title, "Thể loại phim" %>

<div class="max-w-3xl">
  <div class="flex items-center justify-between mb-5">
    <h1 class="text-xl font-bold text-white">Thể loại phim</h1>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-5">

    <%# ── Genre list ── %>
    <div class="lg:col-span-3">
      <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
        <% if @genres.empty? %>
          <div class="px-5 py-10 text-center text-gray-600 text-sm">Chưa có thể loại nào.</div>
        <% else %>
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-800">
                <th class="px-4 py-3 text-xs text-gray-500 font-medium text-left">Tên thể loại</th>
                <th class="px-4 py-3 text-xs text-gray-500 font-medium text-center">Số phim</th>
                <th class="px-4 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              <% @genres.each do |genre| %>
                <tr class="hover:bg-gray-800/40 transition-colors">
                  <td class="px-4 py-3 font-medium text-white"><%= genre.name %></td>
                  <td class="px-4 py-3 text-center text-gray-400"><%= genre.movies.count %></td>
                  <td class="px-4 py-3">
                    <div class="flex gap-2 justify-end">
                      <%= link_to "Sửa", edit_admin_genre_path(genre),
                            class: "text-xs px-2 py-1 bg-yellow-500/20 hover:bg-yellow-500/30 text-yellow-400 rounded-lg" %>
                      <%= link_to "Xoá", admin_genre_path(genre),
                            data: { turbo_method: :delete, turbo_confirm: "Xoá thể loại '#{genre.name}'?" },
                            class: "text-xs px-2 py-1 bg-red-600/20 hover:bg-red-600/30 text-red-400 rounded-lg border border-red-600/30" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% end %>
      </div>
    </div>

    <%# ── Add genre form ── %>
    <div class="lg:col-span-2">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <p class="text-sm font-semibold text-white mb-4">Thêm thể loại mới</p>
        <%= render "admin/shared/errors", record: @genre %>
        <%= form_with model: [:admin, @genre], local: true do |f| %>
          <div class="mb-3">
            <label class="block text-xs text-gray-400 mb-1">Tên thể loại</label>
            <%= f.text_field :name, value: @genre.name,
                  placeholder: "Ví dụ: Hành động",
                  class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white
                          focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500" %>
          </div>
          <%= f.submit "Thêm thể loại",
                class: "w-full py-2 bg-yellow-500 hover:bg-yellow-400 text-gray-900 text-sm font-bold rounded-lg cursor-pointer transition-colors" %>
        <% end %>
      </div>
    </div>

  </div>
</div>
