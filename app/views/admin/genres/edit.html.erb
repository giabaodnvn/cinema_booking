<% content_for :page_title, "Sửa thể loại" %>

<div class="max-w-sm">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to "← Thể loại", admin_genres_path, class: "text-sm text-gray-400 hover:text-white" %>
    <span class="text-gray-700">/</span>
    <span class="text-sm text-gray-300">Chỉnh sửa</span>
  </div>

  <%= render "admin/shared/errors", record: @genre %>

  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <%= form_with model: [:admin, @genre], local: true do |f| %>
      <div class="mb-4">
        <label class="block text-xs text-gray-400 mb-1">Tên thể loại</label>
        <%= f.text_field :name,
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white
                      focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500" %>
      </div>
      <div class="flex gap-3">
        <%= f.submit "Lưu", class: "px-5 py-2 bg-yellow-500 hover:bg-yellow-400 text-gray-900 text-sm font-bold rounded-lg cursor-pointer" %>
        <%= link_to "Huỷ", admin_genres_path, class: "px-5 py-2 bg-gray-700 hover:bg-gray-600 text-gray-300 text-sm rounded-lg" %>
      </div>
    <% end %>
  </div>
</div>
