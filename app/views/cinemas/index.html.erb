<% content_for :title, "Rạp chiếu – CinemaBook" %>

<div class="max-w-5xl mx-auto">

  <%# ── HEADER ── %>
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white">Rạp chiếu phim</h1>
    <p class="text-sm text-gray-400 mt-1">Tìm rạp gần bạn và xem lịch chiếu</p>
  </div>

  <% if @cinemas_by_city.empty? %>
    <div class="text-center py-20 text-gray-500">
      <p class="text-4xl mb-3">🎭</p>
      <p class="text-base">Chưa có rạp chiếu nào.</p>
    </div>
  <% else %>
    <div class="space-y-10">
      <% @cities.each do |city| %>
        <section>
          <%# City heading %>
          <div class="flex items-center gap-3 mb-4">
            <span class="text-xs font-bold text-gray-400 uppercase tracking-widest"><%= city %></span>
            <div class="flex-1 h-px bg-gray-800"></div>
            <span class="text-xs text-gray-600"><%= @cinemas_by_city[city].size %> rạp</span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <% @cinemas_by_city[city].each do |cinema| %>
              <%= link_to cinema_path(cinema), class: "group bg-gray-900 border border-gray-800 rounded-xl p-5
                          hover:border-gray-600 hover:bg-gray-800/60 transition-all duration-200" do %>
                <div class="flex items-start justify-between gap-3">
                  <div class="w-10 h-10 rounded-lg bg-red-600/20 border border-red-500/30 flex items-center
                              justify-center shrink-0 group-hover:bg-red-600/30 transition-colors">
                    <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="font-semibold text-white text-sm group-hover:text-red-400 transition-colors truncate">
                      <%= cinema.name %>
                    </p>
                    <p class="text-xs text-gray-400 mt-1 line-clamp-2"><%= cinema.address %></p>
                  </div>
                </div>

                <div class="mt-4 flex items-center justify-between text-xs text-gray-500">
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/>
                    </svg>
                    <%= cinema.rooms.size %> phòng chiếu
                  </span>
                  <% if cinema.phone.present? %>
                    <span><%= cinema.phone %></span>
                  <% end %>
                </div>

                <div class="mt-3 pt-3 border-t border-gray-800 flex items-center justify-between">
                  <span class="text-xs text-gray-500">Xem lịch chiếu</span>
                  <svg class="w-4 h-4 text-gray-500 group-hover:text-red-400 group-hover:translate-x-0.5 transition-all"
                       fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>
  <% end %>

</div>
