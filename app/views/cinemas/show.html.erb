<% content_for :title, "#{@cinema.name} – CinemaBook" %>

<div class="max-w-5xl mx-auto">

  <%# ── BREADCRUMB ── %>
  <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
    <%= link_to "Rạp chiếu", cinemas_path, class: "hover:text-white transition-colors" %>
    <span>/</span>
    <span class="text-white"><%= @cinema.name %></span>
  </nav>

  <%# ── CINEMA INFO ── %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-8">
    <div class="flex items-start gap-5">
      <div class="w-14 h-14 rounded-xl bg-red-600/20 border border-red-500/30 flex items-center justify-center shrink-0">
        <svg class="w-7 h-7 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
      </div>
      <div class="flex-1">
        <h1 class="text-xl font-bold text-white"><%= @cinema.name %></h1>
        <p class="text-sm text-gray-400 mt-1"><%= @cinema.address %>, <%= @cinema.city %></p>
        <div class="flex flex-wrap gap-4 mt-3 text-xs text-gray-500">
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/>
            </svg>
            <%= @cinema.rooms.size %> phòng chiếu
          </span>
          <% if @cinema.phone.present? %>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <%= @cinema.phone %>
            </span>
          <% end %>
          <% @cinema.rooms.group_by(&:room_type).each do |type, rooms| %>
            <span class="px-2 py-0.5 rounded bg-gray-800 text-gray-400">
              <%= room_type_label(type) %> × <%= rooms.size %>
            </span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── SHOWTIMES ── %>
  <% if @showtimes_by_date.empty? %>
    <div class="text-center py-16 text-gray-500">
      <p class="text-3xl mb-3">🎬</p>
      <p class="text-sm">Hiện chưa có suất chiếu nào tại rạp này.</p>
      <%= link_to "Xem phim đang chiếu", movies_path, class: "mt-3 inline-block text-sm text-red-400 hover:text-red-300" %>
    </div>
  <% else %>
    <h2 class="text-base font-semibold text-white mb-5">Lịch chiếu sắp tới</h2>

    <div class="space-y-8">
      <% @showtimes_by_date.each do |date, showtimes| %>
        <div>
          <%# Date heading %>
          <div class="flex items-center gap-3 mb-4">
            <div class="px-3 py-1 rounded-lg bg-gray-800 border border-gray-700 text-center min-w-14">
              <p class="text-xs text-gray-400 uppercase"><%= I18n.l(date, format: "%a") %></p>
              <p class="text-lg font-bold text-white leading-none"><%= date.day %></p>
              <p class="text-xs text-gray-500"><%= I18n.l(date, format: "%b") %></p>
            </div>
            <div class="flex-1 h-px bg-gray-800"></div>
          </div>

          <%# Group by movie within this date %>
          <% showtimes.group_by(&:movie).each do |movie, movie_showtimes| %>
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-3">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-11 rounded bg-gray-800 shrink-0 overflow-hidden">
                  <% if movie.poster.attached? %>
                    <%= image_tag movie.poster, class: "w-full h-full object-cover" %>
                  <% elsif movie.poster_url.present? %>
                    <%= image_tag movie.poster_url, class: "w-full h-full object-cover" %>
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center text-xs font-bold text-gray-500">
                      <%= movie.title.first.upcase %>
                    </div>
                  <% end %>
                </div>
                <div>
                  <%= link_to movie.title, movie_path(movie),
                        class: "text-sm font-semibold text-white hover:text-red-400 transition-colors" %>
                  <p class="text-xs text-gray-500 mt-0.5">
                    <%= movie.age_rating.presence || "Mọi lứa tuổi" %> &bull; <%= format_duration(movie.duration) %>
                  </p>
                </div>
              </div>

              <div class="flex flex-wrap gap-2">
                <% movie_showtimes.each do |showtime| %>
                  <%= link_to showtime_seats_path(showtime),
                        class: "group flex flex-col items-center bg-gray-800 hover:bg-red-600/20 border
                                border-gray-700 hover:border-red-500/50 rounded-lg px-3 py-2 transition-all" do %>
                    <span class="text-sm font-bold text-white group-hover:text-red-400 transition-colors font-mono">
                      <%= I18n.l(showtime.start_time, format: :time) %>
                    </span>
                    <span class="text-xs text-gray-500 mt-0.5"><%= showtime.room.name %></span>
                    <span class="text-xs text-gray-400 font-medium mt-0.5"><%= format_price(showtime.price) %></span>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
