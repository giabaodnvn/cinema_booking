<% content_for :title, "Lịch chiếu – CinemaBook" %>

<div class="max-w-5xl mx-auto">

  <%# ── HEADER ── %>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-white">Lịch chiếu</h1>
    <p class="text-sm text-gray-400 mt-1">Xem tất cả suất chiếu trong 7 ngày tới</p>
  </div>

  <%# ── DATE PICKER TABS ── %>
  <div class="flex gap-2 overflow-x-auto pb-1 mb-6 scrollbar-none">
    <% @date_range.each do |date| %>
      <% active = date == @selected_date %>
      <%= link_to showtimes_path(date: date, cinema_id: params[:cinema_id], movie_id: params[:movie_id]),
            class: "flex flex-col items-center px-4 py-2.5 rounded-xl border transition-all shrink-0
                    #{active ? 'bg-red-600 border-red-500 text-white' : 'bg-gray-900 border-gray-700 text-gray-400 hover:border-gray-500 hover:text-white'}" do %>
        <span class="text-xs uppercase font-medium"><%= I18n.l(date, format: "%a") %></span>
        <span class="text-xl font-bold leading-tight"><%= date.day %></span>
        <span class="text-xs"><%= I18n.l(date, format: "%b") %></span>
        <% if date == Date.current %>
          <span class="text-xs mt-0.5 <%= active ? 'text-red-200' : 'text-red-400' %>">Hôm nay</span>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%# ── FILTERS ── %>
  <%= form_with url: showtimes_path, method: :get, data: { turbo_frame: "_top" } do |f| %>
    <%= f.hidden_field :date, value: @selected_date %>
    <div class="flex flex-col sm:flex-row gap-3 mb-6">
      <div class="flex-1">
        <%= f.select :cinema_id,
              options_from_collection_for_select(@cinemas, :id, :name, params[:cinema_id]),
              { include_blank: "Tất cả rạp chiếu" },
              class: "w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-2.5 text-sm text-white
                      focus:outline-none focus:border-red-500" %>
      </div>
      <div class="flex-1">
        <%= f.select :movie_id,
              options_from_collection_for_select(@movies, :id, :title, params[:movie_id]),
              { include_blank: "Tất cả phim" },
              class: "w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-2.5 text-sm text-white
                      focus:outline-none focus:border-red-500" %>
      </div>
      <%= f.submit "Lọc",
            class: "px-6 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold
                    rounded-xl transition-colors cursor-pointer" %>
      <% if params[:cinema_id].present? || params[:movie_id].present? %>
        <%= link_to "Xoá lọc", showtimes_path(date: @selected_date),
              class: "px-4 py-2.5 text-sm text-gray-400 hover:text-white border border-gray-700
                      hover:border-gray-500 rounded-xl transition-colors text-center" %>
      <% end %>
    </div>
  <% end %>

  <%# ── RESULTS ── %>
  <% if @showtimes_by_movie.empty? %>
    <div class="text-center py-16 text-gray-500">
      <p class="text-3xl mb-3">🎬</p>
      <p class="text-sm">Không có suất chiếu nào trong ngày này.</p>
      <% if params[:cinema_id].present? || params[:movie_id].present? %>
        <%= link_to "Xem tất cả suất chiếu", showtimes_path(date: @selected_date),
              class: "mt-3 inline-block text-sm text-red-400 hover:text-red-300" %>
      <% end %>
    </div>
  <% else %>
    <div class="space-y-4">
      <% @showtimes_by_movie.each do |movie, showtimes| %>
        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">

          <%# Movie header %>
          <div class="flex items-center gap-4 p-4 border-b border-gray-800">
            <div class="w-12 h-16 rounded-lg bg-gray-800 shrink-0 overflow-hidden">
              <% if movie.poster.attached? %>
                <%= image_tag movie.poster, class: "w-full h-full object-cover" %>
              <% elsif movie.poster_url.present? %>
                <%= image_tag movie.poster_url, class: "w-full h-full object-cover" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center text-base font-bold text-gray-500">
                  <%= movie.title.first.upcase %>
                </div>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <%= link_to movie.title, movie_path(movie),
                    class: "text-base font-bold text-white hover:text-red-400 transition-colors" %>
              <div class="flex flex-wrap items-center gap-2 mt-1">
                <%= age_rating_badge(movie.age_rating) %>
                <span class="text-xs text-gray-400"><%= format_duration(movie.duration) %></span>
                <% movie.genres.each do |genre| %>
                  <span class="text-xs px-2 py-0.5 rounded-full bg-gray-800 text-gray-400"><%= genre.name %></span>
                <% end %>
              </div>
            </div>
          </div>

          <%# Showtimes grouped by cinema %>
          <div class="p-4 space-y-4">
            <% showtimes.group_by { |s| s.room.cinema }.each do |cinema, cinema_showtimes| %>
              <div>
                <p class="text-xs font-semibold text-gray-400 mb-2 flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  </svg>
                  <%= link_to cinema.name, cinema_path(cinema), class: "hover:text-white transition-colors" %>
                  <span class="text-gray-600 font-normal">— <%= cinema.city %></span>
                </p>
                <div class="flex flex-wrap gap-2">
                  <% cinema_showtimes.each do |showtime| %>
                    <%= link_to showtime_seats_path(showtime),
                          class: "group flex flex-col items-center bg-gray-800 hover:bg-red-600/20 border
                                  border-gray-700 hover:border-red-500/50 rounded-lg px-3 py-2 transition-all" do %>
                      <span class="text-sm font-bold text-white group-hover:text-red-400 transition-colors font-mono">
                        <%= I18n.l(showtime.start_time, format: :time) %>
                      </span>
                      <span class="text-xs text-gray-500 mt-0.5"><%= showtime.room.name %></span>
                      <span class="text-xs text-gray-400 font-medium mt-0.5"><%= format_price(showtime.price) %></span>
                    <% end %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

        </div>
      <% end %>
    </div>
  <% end %>

</div>
