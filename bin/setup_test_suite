cat > spec/models/user_spec.rb <<'RUBY'
require "rails_helper"

RSpec.describe User, type: :model do
  # Associations
  it { should have_many(:bookings).dependent(:restrict_with_error) }
  it { should have_many(:created_bookings).class_name("Booking") }

  # Validations
  it { should validate_presence_of(:name) }
  it { should validate_presence_of(:email) }

  # Enums
  it { should define_enum_for(:role).with_values(customer: 0, staff: 1, admin: 2) }

  describe "#can_access_admin?" do
    it "returns true only for admin" do
      expect(build(:user, :admin).can_access_admin?).to be true
      expect(build(:user, :staff).can_access_admin?).to be false
      expect(build(:user).can_access_admin?).to be false
    end
  end

  describe "#can_access_staff?" do
    it "returns true for staff and admin" do
      expect(build(:user, :staff).can_access_staff?).to be true
      expect(build(:user, :admin).can_access_staff?).to be true
      expect(build(:user).can_access_staff?).to be false
    end
  end

  describe "phone validation" do
    it "accepts blank phone" do
      expect(build(:user, phone: "")).to be_valid
    end

    it "accepts valid phone" do
      expect(build(:user, phone: "0901234567")).to be_valid
    end

    it "rejects phone with letters" do
      expect(build(:user, phone: "abc")).not_to be_valid
    end
  end
end
