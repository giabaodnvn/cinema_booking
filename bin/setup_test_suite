require "rails_helper"

# Verifies that only staff (or admin) users can access the staff booking area.
RSpec.describe "Staff::Bookings authorization", type: :request do
  let(:customer) { create(:user) }
  let(:staff)    { create(:user, :staff) }
  let(:admin)    { create(:user, :admin) }

  describe "GET /staff/bookings" do
    context "when not authenticated" do
      it "redirects to login" do
        get staff_bookings_path
        expect(response).to redirect_to(new_user_session_path)
      end
    end

    context "when authenticated as a customer" do
      before { sign_in customer }

      it "redirects to root" do
        get staff_bookings_path
        expect(response).to redirect_to(root_path)
      end
    end

    context "when authenticated as staff" do
      before { sign_in staff }

      it "returns HTTP 200" do
        get staff_bookings_path
        expect(response).to have_http_status(:ok)
      end
    end

    context "when authenticated as admin (can also access staff area)" do
