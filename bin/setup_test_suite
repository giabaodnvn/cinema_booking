cat > spec/requests/admin/bookings_spec.rb <<'RUBY'
require "rails_helper"

# Verifies that only admin users can access the admin bookings area.
# Staff and customers must be redirected.
RSpec.describe "Admin::Bookings authorization", type: :request do
  let(:customer) { create(:user) }
  let(:staff)    { create(:user, :staff) }
  let(:admin)    { create(:user, :admin) }

  describe "GET /admin/bookings" do
    context "when not authenticated" do
      it "redirects to login" do
        get admin_bookings_path
        expect(response).to redirect_to(new_user_session_path)
      end
    end

    context "when authenticated as a customer" do
      before { sign_in customer }

      it "redirects to root with access-denied" do
        get admin_bookings_path
        expect(response).to redirect_to(root_path)
      end
    end

    context "when authenticated as staff" do
      before { sign_in staff }

      it "redirects to root (admin only area)" do
        get admin_bookings_path
        expect(response).to redirect_to(root_path)
      end
    end

    context "when authenticated as admin" do
      before { sign_in admin }

      it "returns HTTP 200" do
        get admin_bookings_path
        expect(response).to have_http_status(:ok)
      end
    end
  end

  describe "GET /admin/reports" do
    context "when not authenticated" do
      it "redirects to login" do
        get admin_reports_path
        expect(response).to redirect_to(new_user_session_path)
      end
    end

    context "when authenticated as admin" do
      before { sign_in admin }

      it "returns HTTP 200" do
        get admin_reports_path
        expect(response).to have_http_status(:ok)
      end
    end
  end
end
RUBY

