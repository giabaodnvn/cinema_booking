cat > spec/models/booking_spec.rb <<'RUBY'
require "rails_helper"

RSpec.describe Booking, type: :model do
  # Associations
  it { should belong_to(:user).optional(true) }
  it { should belong_to(:showtime) }
  it { should have_many(:booking_seats).dependent(:destroy) }
  it { should have_one(:payment).dependent(:destroy) }

  # Validations
  it { should validate_presence_of(:booking_code) }
  it { should validate_uniqueness_of(:booking_code) }
  it { should validate_numericality_of(:total_amount).is_greater_than_or_equal_to(0) }

  # Enums
  it { should define_enum_for(:booking_type).with_values(online: 0, offline: 1) }
  it { should define_enum_for(:status).with_values(pending: 0, paid: 1, cancelled: 2) }

  describe "#customer_display_name" do
    context "with registered user" do
      it "returns user name" do
        user    = build(:user, name: "Tran Thi B")
        booking = build(:booking, user: user)
        expect(booking.customer_display_name).to eq("Tran Thi B")
      end
    end

    context "with guest (no user)" do
      it "returns guest_name when set" do
        booking = build(:booking, :offline_guest, guest_name: "Walk-in Guest")
        expect(booking.customer_display_name).to eq("Walk-in Guest")
      end

      it "falls back to 'Khách vãng lai'" do
        booking = build(:booking, :offline_guest, guest_name: nil)
        expect(booking.customer_display_name).to eq("Khách vãng lai")
      end
    end
  end

  describe "booking_code auto-generation" do
    it "generates a booking_code before creation" do
      booking = create(:booking)
      expect(booking.booking_code).to match(/\ABK[A-Z0-9]{8}\z/)
    end

    it "generates unique codes" do
      codes = create_list(:booking, 5).map(&:booking_code)
      expect(codes.uniq.length).to eq(5)
    end
  end

  describe "scopes" do
    let!(:online_booking)  { create(:booking, booking_type: :online) }
    let!(:offline_booking) { create(:booking, :offline_guest, booking_type: :offline) }

    it ".offline_bookings returns only offline" do
      expect(Booking.offline_bookings).to include(offline_booking)
      expect(Booking.offline_bookings).not_to include(online_booking)
    end
  end
end
RUBY

cat > spec/models/showtime_spec.rb <<'RUBY'
require "rails_helper"

RSpec.describe Showtime, type: :model do
  # Associations
  it { should belong_to(:movie) }
  it { should belong_to(:room) }
  it { should have_many(:bookings).dependent(:restrict_with_error) }

  # Validations
  it { should validate_presence_of(:start_time) }
  it { should validate_presence_of(:end_time) }
  it { should validate_numericality_of(:price).is_greater_than(0) }

  # Enums
  it { should define_enum_for(:status).with_values(scheduled: 0, cancelled: 1, finished: 2) }

  describe "end_time_after_start_time validation" do
    it "is invalid when end_time is before start_time" do
      showtime = build(:showtime,
        start_time: 2.days.from_now,
        end_time:   1.day.from_now)
      expect(showtime).not_to be_valid
      expect(showtime.errors[:end_time]).to be_present
    end

    it "is valid when end_time is after start_time" do
      showtime = build(:showtime,
        start_time: 2.days.from_now,
        end_time:   2.days.from_now + 2.hours)
      expect(showtime).to be_valid
    end
  end

  describe "no_room_overlap validation" do
    let!(:existing) { create(:showtime) }

    it "rejects a showtime overlapping an existing one in the same room" do
      overlap = build(:showtime,
        room:       existing.room,
        start_time: existing.start_time + 30.minutes,
        end_time:   existing.end_time   + 30.minutes)
      expect(overlap).not_to be_valid
      expect(overlap.errors[:base]).to be_present
    end

    it "allows a showtime in the same room with no overlap" do
      non_overlap = build(:showtime,
        room:       existing.room,
        start_time: existing.end_time + 15.minutes,
        end_time:   existing.end_time + 2.hours + 15.minutes)
      expect(non_overlap).to be_valid
    end

    it "allows a showtime in a different room at the same time" do
      diff_room = build(:showtime,
        start_time: existing.start_time,
        end_time:   existing.end_time)
      expect(diff_room).to be_valid
    end
  end

  describe "scopes" do
    let!(:future_showtime) { create(:showtime, start_time: 3.days.from_now, end_time: 3.days.from_now + 2.hours) }
    let!(:past_showtime)   { create(:showtime, start_time: 2.days.ago, end_time: 2.days.ago + 2.hours, status: :finished) }

    it ".upcoming returns only future scheduled showtimes" do
      expect(Showtime.upcoming).to include(future_showtime)
      expect(Showtime.upcoming).not_to include(past_showtime)
    end
  end
end
RUBY

# ─────────────────────────────────────────────────────────────────────────────
# SERVICE SPECS
# ─────────────────────────────────────────────────────────────────────────────
cat > spec/services/bookings/create_service_spec.rb <<'RUBY'
require "rails_helper"

RSpec.describe Bookings::CreateService, type: :service do
  # ── Shared setup ──────────────────────────────────────────────────────────
  let(:cinema)   { create(:cinema) }
  let(:room)     { create(:room, cinema: cinema) }
  let(:movie)    { create(:movie) }
  let(:showtime) { create(:showtime, movie: movie, room: room, price: 90_000) }
  let(:seat_a)   { create(:seat, room: room, row_label: "A", seat_number: 1) }
  let(:seat_b)   { create(:seat, room: room, row_label: "A", seat_number: 2) }
  let(:customer) { create(:user) }

  # Helper to call the service
  def call_service(**overrides)
    defaults = { user: customer, showtime: showtime, seat_ids: [seat_a.id, seat_b.id] }
    Bookings::CreateService.call(**defaults.merge(overrides))
  end

  # ── Online booking (happy path) ──────────────────────────────────────────
  describe "successful online booking" do
    subject(:result) { call_service }

    it "returns success" do
      expect(result.success?).to be true
    end

    it "creates exactly one Booking" do
      expect { result }.to change(Booking, :count).by(1)
    end

    it "creates BookingSeat records for each seat" do
      expect { result }.to change(BookingSeat, :count).by(2)
    end

    it "creates a Payment record" do
      expect { result }.to change(Payment, :count).by(1)
    end

    it "sets total_amount to price × seat count" do
      expect(result.booking.total_amount).to eq(90_000 * 2)
    end

    it "creates a pending payment for online booking" do
      expect(result.booking.payment.status).to eq("pending")
    end

    it "sets booking_type to online" do
      expect(result.booking.booking_type).to eq("online")
    end

    it "does not set paid_at for pending payment" do
      expect(result.booking.payment.paid_at).to be_nil
    end
  end

  # ── Offline counter booking with guest ───────────────────────────────────
  describe "successful offline booking for walk-in guest" do
    subject(:result) do
      call_service(
        user:            nil,
        seat_ids:        [seat_a.id],
        booking_type:    :offline,
        payment_method:  :cash,
        payment_status:  :completed,
        guest_name:      "Nguyen Van A",
        guest_phone:     "0901234567"
      )
    end

    it "returns success" do
      expect(result.success?).to be true
    end

    it "creates a booking with no user" do
      expect(result.booking.user).to be_nil
    end

    it "stores guest name and phone" do
      expect(result.booking.guest_name).to eq("Nguyen Van A")
      expect(result.booking.guest_phone).to eq("0901234567")
    end

    it "creates a completed payment" do
      expect(result.booking.payment.status).to eq("completed")
    end

    it "sets paid_at for completed payment" do
      expect(result.booking.payment.paid_at).not_to be_nil
    end

    it "sets booking_type to offline" do
      expect(result.booking.booking_type).to eq("offline")
    end
  end

  # ── Offline booking for registered user at counter ───────────────────────
  describe "offline booking for registered customer at counter" do
    subject(:result) do
      call_service(
        booking_type:   :offline,
        payment_method: :card,
        payment_status: :completed
      )
    end

    it "returns success" do
      expect(result.success?).to be true
    end

    it "links to the registered user" do
      expect(result.booking.user).to eq(customer)
    end
  end

  # ── Validation failures ───────────────────────────────────────────────────
  describe "validation failures" do
    context "no seats selected" do
      subject(:result) { call_service(seat_ids: []) }

      it "returns failure" do
        expect(result.success?).to be false
      end

      it "includes a descriptive error" do
        expect(result.errors.first).to match(/ít nhất 1 ghế/i)
      end

      it "does not create any records" do
        expect { result }.not_to change(Booking, :count)
      end
    end

    context "too many seats (> MAX_SEATS)" do
      let(:many_seats) do
        (1..9).map { |n| create(:seat, room: room, row_label: "B", seat_number: n) }
      end

      subject(:result) { call_service(seat_ids: many_seats.map(&:id)) }

      it "returns failure" do
        expect(result.success?).to be false
      end

      it "includes a max seats error" do
        expect(result.errors.first).to match(/tối đa/i)
      end
    end

    context "no user and no guest_name (anonymous)" do
      subject(:result) { call_service(user: nil, guest_name: nil) }

      it "returns failure" do
        expect(result.success?).to be false
      end
    end

    context "showtime is cancelled" do
      before { showtime.update_columns(status: 1) } # 1 = cancelled

      it "returns failure" do
        expect(call_service.success?).to be false
      end

      it "includes a showtime error" do
        expect(call_service.errors.first).to match(/không còn nhận đặt vé/i)
      end
    end

    context "showtime has already started" do
      before do
        showtime.update_columns(
          start_time: 2.hours.ago,
          end_time:   Time.current - 1.minute
        )
      end

      it "returns failure" do
        expect(call_service.success?).to be false
      end

      it "includes a timing error" do
        expect(call_service.errors.first).to match(/đã bắt đầu/i)
      end
    end

    context "seat in maintenance" do
      before { seat_a.update!(status: :maintenance) }

      it "returns failure" do
        expect(call_service.success?).to be false
      end
    end

    context "seat belongs to a different room" do
      let(:other_room) { create(:room, cinema: cinema) }
      let(:foreign_seat) { create(:seat, room: other_room, row_label: "Z", seat_number: 1) }

      it "returns failure" do
        result = call_service(seat_ids: [foreign_seat.id])
        expect(result.success?).to be false
      end
    end
  end

  # ── Double-booking prevention ─────────────────────────────────────────────
  describe "double-booking prevention" do
    context "seat already booked (active booking exists)" do
      before do
        # First booking succeeds
        Bookings::CreateService.call(
          user:     create(:user),
          showtime: showtime,
          seat_ids: [seat_a.id]
        )
      end

      subject(:result) { call_service(seat_ids: [seat_a.id]) }

      it "returns failure for the conflicting seat" do
        expect(result.success?).to be false
      end

      it "includes a seat-taken error" do
        expect(result.errors.first).to match(/đã được đặt/i)
      end

      it "does not create a duplicate booking" do
        expect { result }.not_to change(Booking, :count)
      end
    end

    context "cancelled booking releases the seat" do
      before do
        first = Bookings::CreateService.call(
          user:     create(:user),
          showtime: showtime,
          seat_ids: [seat_a.id]
        )
        first.booking.update!(status: :cancelled)
      end

      subject(:result) { call_service(seat_ids: [seat_a.id]) }

      it "allows the seat to be rebooked" do
        expect(result.success?).to be true
      end
    end
  end
end
