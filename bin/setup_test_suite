cat > spec/requests/bookings_spec.rb <<'RUBY'
require "rails_helper"

# Tests the customer-facing online booking flow end-to-end.
RSpec.describe "Customer online booking flow", type: :request do
  let(:customer) { create(:user) }
  let(:cinema)   { create(:cinema) }
  let(:room)     { create(:room, cinema: cinema) }
  let(:movie)    { create(:movie) }
  let(:showtime) { create(:showtime, movie: movie, room: room) }
  let(:seat)     { create(:seat, room: room, row_label: "A", seat_number: 1) }

  describe "GET /showtimes/:id/seats (seat selection)" do
    context "when not authenticated" do
      it "redirects to login" do
        get showtime_seats_path(showtime)
        expect(response).to redirect_to(new_user_session_path)
      end
    end

    context "when authenticated as customer" do
      before { sign_in customer }

      it "returns HTTP 200" do
        get showtime_seats_path(showtime)
        expect(response).to have_http_status(:ok)
      end
    end
  end

  describe "POST /showtimes/:showtime_id/bookings (create booking)" do
    context "when not authenticated" do
      it "redirects to login" do
        post showtime_bookings_path(showtime), params: { seat_ids: [seat.id] }
        expect(response).to redirect_to(new_user_session_path)
      end
    end

    context "when authenticated as customer" do
      before { sign_in customer }

      it "creates a booking and redirects to confirmation" do
        post showtime_bookings_path(showtime), params: { seat_ids: [seat.id] }
        expect(response).to redirect_to(confirmation_booking_path(Booking.last))
      end

      it "increments Booking count by 1" do
        expect {
          post showtime_bookings_path(showtime), params: { seat_ids: [seat.id] }
        }.to change(Booking, :count).by(1)
      end

      it "increments Payment count by 1" do
        expect {
          post showtime_bookings_path(showtime), params: { seat_ids: [seat.id] }
        }.to change(Payment, :count).by(1)
      end
    end

    context "double-booking via HTTP" do
      before { sign_in customer }

      it "returns unprocessable_entity on the second request for the same seat" do
        # First booking
        post showtime_bookings_path(showtime), params: { seat_ids: [seat.id] }
        # Second booking — same seat, different session
        second_customer = create(:user)
        sign_in second_customer
        post showtime_bookings_path(showtime), params: { seat_ids: [seat.id] }
        expect(response).to have_http_status(:unprocessable_entity)
      end
    end
  end

  describe "GET /bookings/:id/confirmation" do
    let!(:booking) { create(:booking, user: customer, showtime: showtime) }

    context "when not authenticated" do
      it "redirects to login" do
        get confirmation_booking_path(booking)
        expect(response).to redirect_to(new_user_session_path)
      end
    end

    context "when authenticated as the booking owner" do
      before { sign_in customer }

      it "returns HTTP 200" do
        get confirmation_booking_path(booking)
        expect(response).to have_http_status(:ok)
      end
    end
  end
end
